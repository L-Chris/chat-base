{
  "name": "@rethinkos/chat-base",
  "version": "0.7.1",
  "license": "MIT",
  "exports": {
    ".": "./mod.ts",
    "./core": "./src/core/mod.ts",
    "./openai": "./src/openai/mod.ts",
    "./stream": "./src/stream/mod.ts",
    "./tools": "./src/tools/mod.ts",
    "./adapters": "./src/adapters/mod.ts"
  },
  "imports": {
    "eventsource-parser": "npm:eventsource-parser@^3.0.0",
    "jsonrepair": "npm:jsonrepair@^3.12.0",
    "tokenx": "npm:tokenx@^0.4.1",
    "@hono/hono": "jsr:@hono/hono@^4.8.0"
  },
  "tasks": {
    "check": "deno check mod.ts",
    "test": "deno test --allow-net --allow-read --allow-write --allow-env"
  },
  "publish": {
